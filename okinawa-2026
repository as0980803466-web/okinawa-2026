    <script>
        window.onload = function() { showDay(1); };

        function showDay(dayNum) {
            document.querySelectorAll('.day-section').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.date-btn').forEach(b => b.classList.remove('tab-active'));
            document.getElementById('day-' + dayNum).classList.add('active');
            document.getElementById('btn-' + dayNum).classList.add('tab-active');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>
