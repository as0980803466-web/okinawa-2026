<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>鄭寶寶 2026 沖繩之旅</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-pink: #FFB7C5;
            --soft-yellow: #FFF9E3;
            --sky-blue: #BFEAF2;
            --text-brown: #5D4037;
        }

        * {
            font-family: "Noto Sans TC", sans-serif;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: var(--soft-yellow);
            color: var(--text-brown);
            margin: 0;
            padding: 0;
        }

        .main-header {
            text-align: center;
            padding: 25px 10px;
        }

        .main-header-title {
            font-weight: 900;
            color: #4A5568;
            font-size: clamp(1rem, 5.5vw, 2.1rem); 
            white-space: nowrap;
            letter-spacing: -0.01em;
            display: inline-block;
        }

        .card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 8px 20px -5px rgba(0,0,0,0.05);
            overflow: hidden;
            margin-bottom: 20px;
            border: 1px solid rgba(0,0,0,0.02);
        }

        .img-hero {
            width: 100%;
            height: 140px; 
            object-fit: cover;
            background-color: #eee;
        }

        /* 強化後的連結卡片樣式 */
        .link-card {
            display: flex;
            align-items: center;
            background: #F7FAFC;
            border: 1px solid #E2E8F0;
            border-radius: 16px;
            padding: 12px;
            text-decoration: none !important;
            color: inherit !important;
            margin-top: 10px;
            transition: all 0.2s ease;
            cursor: pointer;
            width: 100%;
        }

        .link-card:active {
            transform: scale(0.97);
            background: #EDF2F7;
        }

        .link-card .icon-circle {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
            font-size: 1.2rem;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
            flex-shrink: 0;
        }

        .link-card .name {
            font-weight: 700;
            font-size: 0.85rem;
            line-height: 1.2;
        }

        .link-card .rating {
            font-size: 0.75rem;
            color: #F6AD55;
            font-weight: bold;
            display: block;
            margin-top: 2px;
        }

        .tab-active {
            background-color: var(--primary-pink) !important;
            color: white !important;
            box-shadow: 0 4px 10px rgba(255, 183, 197, 0.4);
        }

        .day-section {
            display: none;
        }
        .day-section.active {
            display: block;
            animation: fadeIn 0.3s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .weather-banner {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: white;
            padding: 6px 18px;
            border-radius: 50px;
            margin-bottom: 15px;
            font-size: 0.85rem;
            font-weight: 900;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            color: #4A5568;
        }

        .info-box {
            background: #F0FFF4;
            border-left: 5px solid #48BB78;
            padding: 15px;
            border-radius: 0 20px 20px 0;
            margin-top: 15px;
            font-size: 0.8rem;
        }

        .alert-box {
            background: #FFF5F5;
            border-left: 5px solid #F56565;
            padding: 15px;
            border-radius: 0 20px 20px 0;
            margin-top: 15px;
            font-size: 0.8rem;
        }

        .shop-chip {
            display: inline-block;
            background: #EDF2F7;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            margin: 2px;
            font-weight: 700;
        }
        
        .no-scrollbar::-webkit-scrollbar { display: none; }

        /* 優化懶人包按鈕 */
        .bottom-link-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: white;
            border: 1px solid #E2E8F0;
            padding: 10px 18px;
            border-radius: 14px;
            font-size: 10px;
            font-weight: 800;
            color: #4A5568;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
            text-decoration: none !important;
            transition: all 0.2s ease;
        }

        .bottom-link-btn:active {
            background: #EDF2F7;
            transform: scale(0.95);
        }
    </style>
</head>
